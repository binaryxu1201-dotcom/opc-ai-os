{
  "name": "opc-ai-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": { "node": ">=22.12.0" },
  "scripts": {
    "dev": "pnpm --parallel --filter @opc/web --filter @opc/api --filter @opc/worker dev",
    "build": "pnpm --filter @opc/contracts build && pnpm --filter @opc/config build && pnpm --filter @opc/api build && pnpm --filter @opc/worker build && pnpm --filter @opc/web build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "db:generate": "pnpm --filter @opc/db generate",
    "db:migrate": "pnpm --filter @opc/db migrate"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
