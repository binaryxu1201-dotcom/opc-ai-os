NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=3001
DATABASE_URL=postgresql://opc_ai_os_dev:replace-with-local-secret@127.0.0.1:5432/opc_ai_os_dev
REDIS_URL=redis://127.0.0.1:6379
WEB_ORIGIN=http://localhost:3000
ACCESS_TOKEN_SECRET=replace-with-a-32-character-minimum-local-secret
ACCESS_TOKEN_ISSUER=opc-ai-os
ACCESS_TOKEN_AUDIENCE=opc-web
# Private S3/MinIO-compatible export storage. Leave unset when API tests inject storage.
EXPORT_S3_ENDPOINT=http://127.0.0.1:9000
EXPORT_S3_REGION=us-east-1
EXPORT_S3_BUCKET=opc-exports
EXPORT_S3_ACCESS_KEY_ID=replace-with-access-key
EXPORT_S3_SECRET_ACCESS_KEY=replace-with-secret-key
