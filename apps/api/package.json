{
  "name": "@opc/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src test --max-warnings=0",
    "test": "pnpm --filter @opc/contracts build && pnpm --filter @opc/config build && vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "^10.0.2",
    "@opc/config": "workspace:*",
    "@opc/contracts": "workspace:*",
    "bcryptjs": "2.4.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.5.0",
    "jose": "6.1.3",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "^22.13.1",
    "@types/pg": "^8.11.11",
    "@vitest/coverage-v8": "^3.0.7",
    "eslint": "^9.20.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "vitest": "^3.0.7"
  }
}
